{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Standup Siren",
  "version": "0.1.0",
  "identifier": "com.sleepyclaw.standup-siren",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Standup Siren",
        "width": 460,
        "height": 480,
        "resizable": false,
        "visible": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
